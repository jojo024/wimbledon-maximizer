# Copy to wimbledon-maximizer.env (gitignored) and fill in real values.
# Referenced by wimbledon-maximizer.service via EnvironmentFile=.

# Required: change this before the site is reachable from the internet.
# Anyone who knows it can edit or delete the entire database via /admin.
WIM_ADMIN_KEY=change-me-to-something-long-and-random

# uvicorn binds loopback only — Caddy (on the same box) is the only thing
# that can reach it, and terminates TLS in front of it. uvicorn's own
# ProxyHeadersMiddleware already trusts X-Forwarded-For/Proto from 127.0.0.1
# by default, which is exactly Caddy's address here — no extra config needed.
WIM_HOST=127.0.0.1
WIM_PORT=8030
